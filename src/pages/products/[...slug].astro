---
import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/Navbar.astro";
import ProductImage from "../../components/ProductImage.astro";
import ProductCard from "../../components/ProductCard.astro";
import Footer from "../../components/Footer.astro";
import {
  getProductBySlug,
  getRelatedProducts,
  formatPrice,
  getWhatsAppUrl,
  getAllProducts,
  slugify,
} from "../../lib/data";

export async function getStaticPaths() {
  const products = getAllProducts();
  return products.map((product) => ({
    params: { slug: product.slug },
    props: { product },
  }));
}

const { product } = Astro.props;

if (!product) {
  return Astro.redirect("/404");
}

const relatedProducts = getRelatedProducts(product);
const whatsappUrl = getWhatsAppUrl(
  product.whatsapp,
  `Hola, estoy interesado en tu producto: ${product.name}`,
);

const productUrl = `https://webmarket.com/products/${product.slug}`;
const productImage = `https://webmarket.com${product.image}`;

const productSchema: {
  "@context": string;
  "@type": string;
  name: string;
  description: string;
  image: string;
  brand: {
    "@type": string;
    name: string;
  };
  offers: {
    "@type": string;
    price: number;
    priceCurrency: string;
    availability: string;
    url: string;
  };
  aggregateRating?: {
    "@type": string;
    ratingValue: number;
    bestRating: number;
    worstRating: number;
  };
} = {
  "@context": "https://schema.org",
  "@type": "Product",
  name: product.name,
  description: product.shortDescription,
  image: productImage,
  brand: {
    "@type": "Brand",
    name: product.seller,
  },
  offers: {
    "@type": "Offer",
    price: product.price,
    priceCurrency: product.currency,
    availability: "https://schema.org/InStock",
    url: productUrl,
  },
};

if (product.rating > 0) {
  productSchema.aggregateRating = {
    "@type": "AggregateRating",
    ratingValue: product.rating,
    bestRating: 5,
    worstRating: 1,
  };
}

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    {
      "@type": "ListItem",
      position: 1,
      name: "Inicio",
      item: "https://webmarket.com",
    },
    {
      "@type": "ListItem",
      position: 2,
      name: product.category,
      item: `https://webmarket.com/category/${slugify(product.category)}`,
    },
    { "@type": "ListItem", position: 3, name: product.name, item: productUrl },
  ],
};
---

<Layout
  title={`${product.name} — WebMarket Marketplace`}
  description={product.shortDescription}
  ogImage={product.image}
  ogType="product"
  canonical={`/products/${product.slug}`}
>
  <script type="application/ld+json" set:html={JSON.stringify(productSchema)} />
  <script
    type="application/ld+json"
    set:html={JSON.stringify(breadcrumbSchema)}
  />

  <Navbar />

  <main class="product-detail">
    <div class="container">
      <nav class="breadcrumbs">
        <a href="/">Inicio</a>
        <span class="breadcrumb-sep">/</span>
        <a href={`/category/${slugify(product.category)}`}>{product.category}</a
        >
        <span class="breadcrumb-sep">/</span>
        <span class="breadcrumb-current">{product.name}</span>
      </nav>

      <div class="detail-grid">
        <div class="detail-gallery">
          <div class="detail-main-image">
            <ProductImage
              src={product.image}
              alt={product.name}
              priority={true}
            />
          </div>
          {
            product.video && (
              <div class="detail-video">
                <video controls poster={product.image}>
                  <source src={product.video} type="video/mp4" />
                  Your browser does not support the video tag.
                </video>
              </div>
            )
          }
        </div>

        <div class="detail-info">
          <div class="detail-meta-top">
            <span class="detail-category">{product.category}</span>
            <span class="detail-type">{product.type}</span>
            <span class="detail-rating">★ {product.rating}</span>
          </div>

          <h1 class="detail-title">{product.name}</h1>

          <div class="detail-price-row">
            <span class="detail-price"
              >{formatPrice(product.price, product.currency)}</span
            >
          </div>

          <div class="detail-seller">
            <div class="seller-avatar">{product.seller.charAt(0)}</div>
            <div class="seller-info">
              <span class="seller-label">Vendedor</span>
              <span class="seller-name">{product.seller}</span>
            </div>
          </div>

          <p class="detail-description">{product.description}</p>

          <div class="detail-tags">
            {product.tags.map((tag) => <span class="detail-tag">{tag}</span>)}
          </div>

          <div class="detail-actions">
            {
              product.website && (
                <a
                  href={product.website}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="btn btn-outline btn-lg detail-website-btn"
                >
                  <svg
                    width="18"
                    height="18"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <>
                      <circle cx="12" cy="12" r="10" />
                      <line x1="2" y1="12" x2="22" y2="12" />
                      <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z" />
                    </>
                  </svg>
                  Visitar Sitio Web
                </a>
              )
            }
            <a
              href={whatsappUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="btn btn-primary btn-lg detail-whatsapp-btn"
            >
              Contactar por WhatsApp
            </a>
            <span class="detail-action-note"
              >Pregunta, solicita una demo o recibe un presupuesto
              personalizado.</span
            >
          </div>

          <div class="detail-share">
            <span class="share-label">Compartir:</span>
            <a
              href={`https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(Astro.url.href)}`}
              target="_blank"
              rel="noopener noreferrer"
              class="share-link"
              title="Compartir en Facebook">f</a
            >
            <a
              href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(`Mira ${product.name} en WebMarket`)}&url=${encodeURIComponent(Astro.url.href)}`}
              target="_blank"
              rel="noopener noreferrer"
              class="share-link"
              title="Compartir en Twitter">𝕏</a
            >
            <a
              href={`https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(Astro.url.href)}`}
              target="_blank"
              rel="noopener noreferrer"
              class="share-link"
              title="Compartir en LinkedIn">in</a
            >
          </div>
        </div>
      </div>

      {
        relatedProducts.length > 0 && (
          <section class="related-section">
            <h2 class="section-title">Productos Relacionados</h2>
            <p class="section-subtitle">
              También te pueden interesar estos productos similares.
            </p>
            <div class="grid-4">
              {relatedProducts.map((p) => (
                <ProductCard product={p} />
              ))}
            </div>
          </section>
        )
      }
    </div>
  </main>

  <Footer />
</Layout>

<style>
  .product-detail {
    padding: var(--space-2xl) 0 var(--space-4xl);
  }

  .breadcrumbs {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    font-size: 0.85rem;
    color: var(--color-text-tertiary);
    margin-bottom: var(--space-2xl);
  }

  .breadcrumbs a {
    transition: color 0.2s;
  }

  .breadcrumbs a:hover {
    color: var(--color-accent);
  }

  .breadcrumb-sep {
    color: var(--color-border);
  }

  .breadcrumb-current {
    color: var(--color-text-secondary);
  }

  .detail-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-3xl);
    margin-bottom: var(--space-4xl);
  }

  .detail-main-image {
    border-radius: var(--radius-xl);
    overflow: hidden;
    border: 1px solid var(--color-border-light);
  }

  .detail-video {
    margin-top: var(--space-lg);
    border-radius: var(--radius-xl);
    overflow: hidden;
    border: 1px solid var(--color-border-light);
  }

  .detail-video video {
    width: 100%;
    display: block;
  }

  .detail-meta-top {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    margin-bottom: var(--space-md);
    flex-wrap: wrap;
  }

  .detail-category,
  .detail-type {
    font-size: 0.75rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding: 0.25rem 0.75rem;
    border-radius: 100px;
  }

  .detail-category {
    background: var(--color-accent-light);
    color: var(--color-accent);
  }

  .detail-type {
    background: var(--color-highlight-light);
    color: var(--color-highlight);
  }

  .detail-rating {
    font-size: 0.9rem;
    color: var(--color-highlight);
    font-weight: 500;
    margin-left: auto;
  }

  .detail-title {
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    font-weight: 700;
    letter-spacing: -0.025em;
    margin-bottom: var(--space-md);
  }

  .detail-price-row {
    margin-bottom: var(--space-lg);
  }

  .detail-price {
    font-family: var(--font-heading);
    font-size: 2.25rem;
    font-weight: 700;
    color: var(--color-accent);
  }

  .detail-seller {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    margin-bottom: var(--space-xl);
    padding: var(--space-md);
    background: var(--color-bg);
    border-radius: var(--radius-lg);
    border: 1px solid var(--color-border-light);
  }

  .seller-avatar {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: var(--color-accent-light);
    color: var(--color-accent);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-heading);
    font-size: 1.25rem;
    font-weight: 700;
    flex-shrink: 0;
  }

  .seller-info {
    display: flex;
    flex-direction: column;
  }

  .seller-label {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-text-tertiary);
  }

  .seller-name {
    font-weight: 600;
    font-size: 1rem;
  }

  .detail-description {
    font-size: 1rem;
    line-height: 1.7;
    color: var(--color-text-secondary);
    margin-bottom: var(--space-lg);
  }

  .detail-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
    margin-bottom: var(--space-xl);
  }

  .detail-tag {
    font-size: 0.8rem;
    color: var(--color-text-secondary);
    background: var(--color-bg);
    padding: 0.35rem 0.75rem;
    border-radius: 100px;
    border: 1px solid var(--color-border-light);
  }

  .detail-actions {
    margin-bottom: var(--space-lg);
  }

  .detail-whatsapp-btn {
    width: 100%;
    justify-content: center;
  }

  .detail-website-btn {
    width: 100%;
    justify-content: center;
    margin-bottom: var(--space-sm);
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    border: 1px solid var(--color-border-light);
  }

  .detail-website-btn:hover {
    background: var(--color-accent-light);
    border-color: var(--color-accent);
  }

  .detail-action-note {
    display: block;
    text-align: center;
    font-size: 0.8rem;
    color: var(--color-text-tertiary);
    margin-top: var(--space-sm);
  }

  .detail-share {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    padding-top: var(--space-lg);
    border-top: 1px solid var(--color-border-light);
  }

  .share-label {
    font-size: 0.8rem;
    color: var(--color-text-tertiary);
    margin-right: var(--space-sm);
  }

  .share-link {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: var(--color-bg);
    border: 1px solid var(--color-border-light);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-text-secondary);
    transition: all 0.2s;
    text-decoration: none;
  }

  .share-link:hover {
    background: var(--color-accent-light);
    border-color: var(--color-accent);
    color: var(--color-accent);
  }

  .related-section {
    padding-top: var(--space-3xl);
    border-top: 1px solid var(--color-border-light);
  }

  @media (max-width: 768px) {
    .detail-grid {
      grid-template-columns: 1fr;
      gap: var(--space-xl);
    }
    .detail-price {
      font-size: 1.75rem;
    }
    .breadcrumbs {
      flex-wrap: wrap;
      margin-bottom: var(--space-lg);
    }
    .product-detail {
      padding: var(--space-lg) 0 var(--space-3xl);
    }
    .related-section {
      padding-top: var(--space-2xl);
    }
  }
</style>
