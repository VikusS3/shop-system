---
---

<section class="hero">
  <div class="container hero-inner">
    <div class="hero-content">
      <span class="hero-badge">Marketplace Digital Premium</span>
      <h1 class="hero-title">
        Descubre Sistemas<br />
        <span class="hero-highlight">Web Premium</span> y SaaS
      </h1>
      <p class="hero-desc">
        Explora una colección curada de sistemas web profesionales, productos SaaS y servicios digitales.
        Conecta directamente con desarrolladores y vendedores.
      </p>
      <div class="hero-actions">
        <a href="#featured" class="btn btn-primary btn-lg">Ver Productos</a>
        <a href="#hot-product" class="btn btn-secondary btn-lg">Tendencia</a>
      </div>
    </div>
    <div class="hero-visual">
      <div class="hero-graphic">
        <div class="graphic-shape shape-1"></div>
        <div class="graphic-shape shape-2"></div>
        <div class="graphic-shape shape-3"></div>
        <div class="graphic-dot dot-1"></div>
        <div class="graphic-dot dot-2"></div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    padding: var(--space-5xl) 0 var(--space-4xl);
    position: relative;
    overflow: hidden;
  }

  .hero::before {
    content: '';
    position: absolute;
    top: -50%;
    right: -20%;
    width: 600px;
    height: 600px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(13, 115, 119, 0.06) 0%, transparent 70%);
    pointer-events: none;
  }

  .hero-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-4xl);
    align-items: center;
  }

  .hero-badge {
    display: inline-block;
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-accent);
    background: var(--color-accent-light);
    padding: 0.375rem 1rem;
    border-radius: 100px;
    margin-bottom: var(--space-lg);
  }

  .hero-title {
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 700;
    line-height: 1.1;
    letter-spacing: -0.03em;
    margin-bottom: var(--space-lg);
  }

  .hero-highlight {
    color: var(--color-accent);
    position: relative;
  }

  .hero-highlight::after {
    content: '';
    position: absolute;
    bottom: 0.05em;
    left: 0;
    right: 0;
    height: 0.15em;
    background: var(--color-highlight);
    opacity: 0.4;
    border-radius: 2px;
  }

  .hero-desc {
    font-size: 1.1rem;
    line-height: 1.6;
    color: var(--color-text-secondary);
    max-width: 520px;
    margin-bottom: var(--space-xl);
  }

  .hero-actions {
    display: flex;
    gap: var(--space-md);
    flex-wrap: wrap;
  }

  .hero-visual {
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .hero-graphic {
    position: relative;
    width: 400px;
    height: 400px;
  }

  .graphic-shape {
    position: absolute;
    border-radius: 50%;
  }

  .shape-1 {
    width: 280px;
    height: 280px;
    top: 20px;
    left: 60px;
    background: linear-gradient(135deg, rgba(13, 115, 119, 0.15), rgba(212, 163, 115, 0.1));
    border: 1px solid rgba(13, 115, 119, 0.15);
    animation: float 8s ease-in-out infinite;
  }

  .shape-2 {
    width: 180px;
    height: 180px;
    bottom: 40px;
    right: 20px;
    background: linear-gradient(135deg, rgba(212, 163, 115, 0.12), rgba(199, 91, 57, 0.08));
    border: 1px solid rgba(212, 163, 115, 0.15);
    animation: float 6s ease-in-out infinite reverse;
  }

  .shape-3 {
    width: 100px;
    height: 100px;
    top: 50%;
    left: 0;
    background: rgba(13, 115, 119, 0.06);
    border: 1px solid rgba(13, 115, 119, 0.1);
    animation: float 10s ease-in-out infinite;
  }

  .graphic-dot {
    position: absolute;
    border-radius: 50%;
  }

  .dot-1 {
    width: 12px;
    height: 12px;
    background: var(--color-highlight);
    top: 80px;
    right: 60px;
    opacity: 0.4;
  }

  .dot-2 {
    width: 8px;
    height: 8px;
    background: var(--color-accent);
    bottom: 100px;
    left: 100px;
    opacity: 0.3;
  }

  @keyframes float {
    0%, 100% { transform: translateY(0) rotate(0deg); }
    50% { transform: translateY(-20px) rotate(3deg); }
  }

  @media (max-width: 1024px) {
    .hero {
      padding: var(--space-3xl) 0 var(--space-3xl);
    }
    .hero-inner {
      grid-template-columns: 1fr;
      text-align: center;
    }
    .hero-desc {
      max-width: 100%;
    }
    .hero-actions {
      justify-content: center;
    }
    .hero-visual {
      display: none;
    }
  }

  @media (max-width: 640px) {
    .hero {
      padding: var(--space-2xl) 0 var(--space-2xl);
    }
    .hero-desc {
      font-size: 1rem;
    }
    .hero-actions {
      flex-direction: column;
      align-items: stretch;
    }
    .hero-actions .btn {
      justify-content: center;
    }
  }
</style>
