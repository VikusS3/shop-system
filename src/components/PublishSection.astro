---
const whatsappUrl =
  "https://wa.me/51906492166?text=Hola%2C%20me%20gustar%C3%ADa%20publicar%20mi%20sistema%20en%20el%20marketplace.";
---

<section class="publish" id="publish">
  <div class="container">
    <div class="publish-card">
      <div class="publish-content">
        <span class="publish-badge">Para Desarrolladores y Vendedores</span>
        <h2 class="publish-title">¿Quieres Publicar tu Sistema?</h2>
        <p class="publish-desc">
          Llega a miles de compradores potenciales que buscan activamente
          sistemas web, productos SaaS y servicios digitales. Déjanos ayudarte a
          promocionar tu producto ante la audiencia correcta.
        </p>
        <div class="publish-benefits">
          <div class="benefit-item">
            <span class="benefit-icon">✓</span>
            <span>Alcanza compradores motivados</span>
          </div>
          <div class="benefit-item">
            <span class="benefit-icon">✓</span>
            <span>Presentación profesional del producto</span>
          </div>
          <div class="benefit-item">
            <span class="benefit-icon">✓</span>
            <span>Comunicación directa con clientes</span>
          </div>
          <div class="benefit-item">
            <span class="benefit-icon">✓</span>
            <span>Sin cuotas mensuales — publicación simple</span>
          </div>
        </div>
        <a
          href={whatsappUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="btn btn-primary btn-lg publish-btn"
        >
          Contáctanos para Publicar
        </a>
      </div>
      <div class="publish-visual">
        <div class="publish-graphic">
          <div class="publish-shape"></div>
          <div class="publish-card-ui">
            <div class="publish-card-header">
              <span class="publish-dot"></span>
              <span class="publish-dot"></span>
              <span class="publish-dot"></span>
            </div>
            <div class="publish-card-body">
              <div class="publish-line long"></div>
              <div class="publish-line"></div>
              <div class="publish-line short"></div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .publish {
    padding: var(--space-4xl) 0;
  }

  .publish-card {
    display: grid;
    grid-template-columns: 1fr 1fr;
    background: linear-gradient(
      135deg,
      var(--color-text-primary) 0%,
      #2a2a4a 100%
    );
    border-radius: var(--radius-2xl);
    overflow: hidden;
    box-shadow: var(--shadow-xl);
  }

  .publish-content {
    padding: var(--space-3xl);
    color: white;
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
  }

  .publish-badge {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-highlight);
    background: rgba(212, 163, 115, 0.15);
    padding: 0.375rem 1rem;
    border-radius: 100px;
    align-self: flex-start;
  }

  .publish-title {
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    font-weight: 700;
    color: white;
    letter-spacing: -0.02em;
  }

  .publish-desc {
    font-size: 1rem;
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.7);
    max-width: 480px;
  }

  .publish-benefits {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-sm);
  }

  .benefit-item {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    font-size: 0.9rem;
    color: rgba(255, 255, 255, 0.8);
  }

  .benefit-icon {
    color: var(--color-highlight);
    font-weight: 700;
  }

  .publish-visual {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-3xl);
    position: relative;
    overflow: hidden;
  }

  .publish-btn {
    white-space: nowrap;
    width: fit-content;
  }

  .publish-graphic {
    position: relative;
  }

  .publish-shape {
    width: 300px;
    height: 300px;
    border-radius: 50%;
    background: radial-gradient(
      circle,
      rgba(212, 163, 115, 0.1) 0%,
      transparent 70%
    );
    position: absolute;
    top: -50px;
    right: -50px;
  }

  .publish-card-ui {
    width: 240px;
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: var(--radius-lg);
    overflow: hidden;
    backdrop-filter: blur(8px);
  }

  .publish-card-header {
    display: flex;
    gap: 6px;
    padding: 1rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  }

  .publish-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.15);
  }

  .publish-dot:first-child {
    background: #c75b39;
  }
  .publish-dot:nth-child(2) {
    background: var(--color-highlight);
  }
  .publish-dot:nth-child(3) {
    background: var(--color-accent);
  }

  .publish-card-body {
    padding: 1rem;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .publish-line {
    height: 8px;
    background: rgba(255, 255, 255, 0.08);
    border-radius: 4px;
  }

  .publish-line.long {
    width: 100%;
  }
  .publish-line {
    width: 80%;
  }
  .publish-line.short {
    width: 50%;
  }

  @media (max-width: 768px) {
    .publish-card {
      grid-template-columns: 1fr;
    }
    .publish-content {
      padding: var(--space-2xl);
    }
    .publish-visual {
      display: none;
    }
    .publish-benefits {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 480px) {
    .publish-content {
      padding: var(--space-xl);
    }
    .publish-title {
      font-size: 1.5rem;
    }
    .publish .btn {
      width: 100%;
      justify-content: center;
      white-space: nowrap;
    }
  }
</style>
